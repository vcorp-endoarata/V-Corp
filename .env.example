# V-Corp environment variables — copy to `.env` (gitignored) and fill in.
# Never commit real secrets.

# --- Discord (operations notifications) ---
# Channel webhook URL. Create one in Discord:
#   Channel ⚙ → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME='V-Corp Bot'
# DISCORD_AVATAR_URL='https://example.com/avatar.png'

# --- Stripe (livemode) ---
# Restricted key with read access to products/prices/subscriptions/charges.
STRIPE_API_KEY=

