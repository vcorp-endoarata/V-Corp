# よりそい — Next.js LP env
# Copy to `.env.local` (gitignored) and fill in.

# --- Supabase (yorisoi project) ---
# 新プロジェクト切替時はここを書き換え + Vercel 環境変数も更新
# 初回セットアップ: supabase/bootstrap.sql を SQL Editor で実行すること
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://yorisoi.community

# --- Resend (programmatic email: notifications etc.) ---
# 未設定の場合: 通知 DB には記録されるがメール送信はスキップ
RESEND_API_KEY=
EMAIL_FROM=よりそい <hello@send.yorisoi.community>

# --- Stripe (よりそい account: acct_1TT2A6GyeDCNGcHG, livemode) ---
# Public — exposed to browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_1TT2UgGyeDCNGcHGjKQhgeec
# Server-only — never expose to client
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
